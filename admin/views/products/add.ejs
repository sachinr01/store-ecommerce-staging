                                                        <div
                                                          class="border rounded d-flex align-items-center justify-content-center bg-light"
                                                          style="width:70px;height:70px;cursor:pointer;" onclick="openMedia({
                                                      urlInput:   'var_gallery_image_<%= v.ID %>',
                                                      titleInput: 'var_gallery_image_titles_<%= v.ID %>',
                                                      altInput:   'var_gallery_image_alts_<%= v.ID %>',
                                                      container:  'varGallery_<%= v.ID %>',
                                                      multiple:   true
                                                    })">
                                                          <i data-feather="plus"></i>
                                                        </div>
                                                        <% if (v.gallery && v.gallery.length> 0) { %>
                                                          <% v.gallery.forEach(function(img) { %>
                                                            <div style="position:relative;width:70px;height:70px;">
                                                              <img src="<%= img.url %>" class="rounded border"
                                                                style="width:70px;height:70px;object-fit:cover;" />
                                                              <input type="hidden"
                                                                name="var_gallery_image_<%= v.ID %>[]"
                                                                value="<%= img.url %>">
                                                              <input type="hidden"
                                                                name="var_gallery_image_titles_<%= v.ID %>[]"
                                                                value="<%= img.title || '' %>">
