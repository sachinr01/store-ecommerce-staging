                                                          id="var_featured_image_<%= v.ID %>"
                                                          value="<%= v.thumbnail_url || '' %>">
                                                        <input type="hidden" name="var_featured_image_title_<%= v.ID %>"
                                                          id="var_featured_image_title_<%= v.ID %>"
                                                          value="<%= v.title || '' %>">
                                                        <input type="hidden" name="var_featured_image_alt_<%= v.ID %>"
                                                          id="var_featured_image_alt_<%= v.ID %>"
                                                          value="<%= v.alt || '' %>">
                                                  </div>

                                                  <!-- Variation Gallery -->
                                                  <div class="mb-3">
                                                    <label class="form-label small fw-semibold d-block">Variation
                                                      Gallery</label>
                                                    <div class="border rounded p-2">
                                                      <div class="d-flex flex-wrap gap-2" id="varGallery_<%= v.ID %>">
