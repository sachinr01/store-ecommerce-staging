<%- include('../partials/head') %>

  <% var p=locals.product || null; var isEdit=!!p; var selAttrs=locals.selectedAttributes || {}; var
    attrTypes=locals.attributeTypes || []; var varList=locals.variations || []; %>

    <%- include('../partials/navbar') %>
      <%- include('../partials/sidebar') %>

        <div class="page-wrapper">

          <div class="page-breadcrumb">
            <div class="row">
              <div class="col-7 align-self-center">
                <h4 class="page-title">
                  <%= isEdit ? 'Edit Product' : 'Add Product' %>
                </h4>
                <div class="d-flex align-items-center">
                  <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                      <li class="breadcrumb-item"><a href="/store/admin/dashboard">Home</a></li>
                      <li class="breadcrumb-item"><a href="/store/admin/products">Products</a></li>
                      <li class="breadcrumb-item active">
                        <%= isEdit ? 'Edit' : 'Add' %>
                      </li>
                    </ol>
                  </nav>
                </div>
              </div>
              <div class="col-5 align-self-center text-end">
                <a href="/store/admin/products" class="btn-view-product btn-view-product--inline na-view-all-btn" title="Back to Products">
                  <div class=" align-items-center">
                    <i data-feather="arrow-left" class="feather-sm me-1"></i> Back to Products
                  </div>
                </a>
               <% if (isEdit) { %>
                <!-- View Product -->
                <a href="/store/shop/product/<%= product.product_url %>" target="_blank"
                  class="btn-view-second btn-view-second--inline na-view-all-btn" title="View Product">
                  <div class="d-flex align-items-center gap-2">
                    View Product Page <i data-feather="external-link" class=" feather-sm"></i>
                  </div>
                </a>
                <% } %>
              </div>
            </div>
          </div>

          <div class="container-fluid">

            <% if (locals.errors) { %>
              <div class="alert alert-danger alert-dismissible fade show">
                <i data-feather="alert-circle" class="feather-sm me-1"></i>
                <%= locals.errors %>
                  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
              </div>
              <% } %>

                <form action="<%= isEdit ? '/store/admin/products/update/' + p.ID : '/store/admin/products/store' %>"
                  method="POST" enctype="multipart/form-data" id="productForm">

                  <div class="row">

                    <!-- LEFT COLUMN -->
                    <div class="col-lg-8">

                      <div class="card mb-3">
                        <div class="card-body">
                          <h4 class="card-title mb-3 pb-3 border-bottom">Product Information</h4>

                          <div class="mb-3">
                            <label class="form-label fw-semibold">Product Title <span
                                class="text-danger">*</span></label>
                            <input type="text" name="product_title" class="form-control form-control-lg"
                              placeholder="Enter product name..." value="<%= isEdit ? p.product_title : '' %>"
                              required />
                          </div>

                          <div class="mb-3">
                            <label class="form-label fw-semibold">Product URL (Slug)</label>
                            <div class="input-group">
                              <span class="input-group-text text-muted">/store/</span>
                              <input type="text" name="product_url" id="productUrl" class="form-control"
                                placeholder="product-url-slug" value="<%= isEdit ? (p.product_url || '') : '' %>" />
                            </div>
                            <small class="text-muted">Auto-generated from title if left empty</small>
                          </div>

                          <div class="mb-3">
                            <label class="form-label fw-semibold">Short Description</label>
                            <textarea name="product_short_desc" id="product_short_desc" class="form-control" rows="3"
                              placeholder="Brief product description..."><%= isEdit ? (p.product_short_desc || '') : '' %></textarea>
                          </div>

                          <div class="mb-3">
                            <label class="form-label fw-semibold">Full Description</label>
                            <textarea name="product_content" class="form-control" rows="8"
                              placeholder="Detailed product description..."
                              id="productContent"><%= isEdit ? (p.product_content || '') : '' %></textarea>
                          </div>
                        </div>
                      </div>

                      <!-- Product Data Tabs -->
                      <div class="card mb-3">
                        <div class="card-body">
                          <div class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom">
                            <h4 class="card-title mb-0">Product Data</h4>
                            <div class="d-flex align-items-center gap-2">
                              <label class="fw-semibold mb-0">Type:</label>
                              <select name="product_type" id="productType" class="form-select form-select-sm"
                                style="width:180px;" onchange="onProductTypeChange(this.value)">
                                <option value="product" <%=(!isEdit || (p.product_type==='product' &&
                                  varList.length===0)) ? 'selected' : '' %>>Simple Product</option>
                                <option value="product_variation" <%=(isEdit && varList.length> 0) ? 'selected' : ''
                                  %>>Variable Product</option>
                              </select>
                            </div>
                          </div>

                          <ul class="nav nav-tabs mb-3" id="productDataTabs">
                            <li class="nav-item">
                              <a class="nav-link active" data-bs-toggle="tab" href="#tab-general">
                                <i data-feather="dollar-sign" class="feather-sm me-1"></i> General
                              </a>
                            </li>
                            <li class="nav-item">
                              <a class="nav-link" data-bs-toggle="tab" href="#tab-inventory">
                                <i data-feather="package" class="feather-sm me-1"></i> Inventory
                              </a>
                            </li>
                            <li class="nav-item">
                              <a class="nav-link" data-bs-toggle="tab" href="#tab-attributes">
                                <i data-feather="sliders" class="feather-sm me-1"></i> Attributes
                              </a>
                            </li>
                            <li class="nav-item" id="variationsTabItem" style="display:none;">
                              <a class="nav-link" data-bs-toggle="tab" href="#tab-variations">
                                <i data-feather="layers" class="feather-sm me-1"></i> Variations
                                <% if (varList.length> 0) { %>
                                  <span class="badge bg-primary rounded-pill ms-1">
                                    <%= varList.length %>
                                  </span>
                                  <% } %>
                              </a>
                            </li>
                          </ul>

                          <div class="tab-content">

                            <!-- General Tab -->
                            <div class="tab-pane fade show active" id="tab-general">
                              <div class="row">
                                <div class="col-md-6">
                                  <div class="mb-3">
                                    <label class="form-label fw-semibold">Regular Price (₹)</label>
                                    <div class="input-group">
                                      <span class="input-group-text">₹</span>
                                      <input type="number" name="regular_price" class="form-control" placeholder="0.00"
                                        step="0.01" min="0" value="<%= isEdit ? (p.regular_price || '') : '' %>" />
                                    </div>
                                  </div>
                                </div>
                                <div class="col-md-6">
                                  <div class="mb-3">
                                    <label class="form-label fw-semibold">Sale Price (₹)</label>
                                    <div class="input-group">
                                      <span class="input-group-text">₹</span>
                                      <input type="number" name="sale_price" class="form-control" placeholder="0.00"
                                        step="0.01" min="0" value="<%= isEdit ? (p.sale_price || '') : '' %>" />
                                    </div>
                                  </div>
                                </div>
                                <div class="col-md-6">
                                  <div class="mb-3">
                                    <label class="form-label fw-semibold">Sale Start Date</label>
                                    <input type="date" name="sale_price_dates_from" class="form-control"
                                      value="<%= isEdit ? (p.sale_price_dates_from || '') : '' %>" />
                                  </div>
                                </div>
                                <div class="col-md-6">
                                  <div class="mb-3">
                                    <label class="form-label fw-semibold">Sale End Date</label>
                                    <input type="date" name="sale_price_dates_to" class="form-control"
                                      value="<%= isEdit ? (p.sale_price_dates_to || '') : '' %>" />
                                  </div>
                                </div>
                                <div class="col-md-6">
                                  <div class="mb-3">
                                    <label class="form-label fw-semibold">Weight (kg)</label>
                                    <input type="number" name="weight" class="form-control" placeholder="00"
                                       min="0" value="<%= isEdit ? (p.weight || '') : '' %>" />
                                  </div>
                                </div>
                                <div class="col-md-6">
                                  <div class="mb-3">
                                    <label class="form-label fw-semibold">Length (cm)</label>
                                    <input type="number" name="length" class="form-control" placeholder="00"
                                       min="0" value="<%= isEdit ? (p.length || '') : '' %>" />
                                  </div>
                                </div>
                                <div class="col-md-6">
                                  <div class="mb-3">
                                    <label class="form-label fw-semibold">Breadth (cm)</label>
                                    <input type="number" name="breadth" class="form-control" placeholder="00"
                                       min="0" value="<%= isEdit ? (p.breadth || '') : '' %>" />
                                  </div>
                                </div>
                                <div class="col-md-6">
                                  <div class="mb-3">
                                    <label class="form-label fw-semibold">Height (cm)</label>
                                    <input type="number" name="height" class="form-control" placeholder="00"
                                       min="0" value="<%= isEdit ? (p.height || '') : '' %>" />
                                  </div>
                                </div>
                              </div>
                            </div>

                            <!-- Inventory Tab -->
                            <div class="tab-pane fade" id="tab-inventory">
                              <div class="row">
                                <div class="col-md-6">
                                  <div class="mb-3">
                                    <label class="form-label fw-semibold">SKU</label>
                                    <input type="text" name="sku" class="form-control" placeholder="Unique product SKU"
                                      value="<%= isEdit ? (p.sku || '') : '' %>" />
                                    <small class="text-muted">Stock Keeping Unit</small>
                                  </div>
                                </div>
                                <div class="col-md-6">
                                  <div class="mb-3">
                                    <label class="form-label fw-semibold">Stock Status</label>
                                    <select name="stock_status" class="form-select">
                                      <option value="instock" <%=(!isEdit || p.stock_status==='instock' ) ? 'selected'
                                        : '' %>>In Stock</option>
                                      <option value="outofstock" <%=(isEdit && p.stock_status==='outofstock' )
                                        ? 'selected' : '' %>>Out of Stock</option>
                                      <option value="onbackorder" <%=(isEdit && p.stock_status==='onbackorder' )
                                        ? 'selected' : '' %>>On Backorder</option>
                                    </select>
                                  </div>
                                </div>
                                <div class="col-md-6">
                                  <div class="mb-3">
                                    <label class="form-label fw-semibold">Stock Quantity</label>
                                    <input type="number" name="stock" class="form-control" min="0" placeholder="0"
                                      value="<%= isEdit ? (p.stock || '') : '' %>" />
                                  </div>
                                </div>
                              </div>
                            </div>

                            <!-- ATTRIBUTES TAB -->
                            <div class="tab-pane fade" id="tab-attributes">
                              <div class="alert alert-light border small py-2 mb-3">
                                <strong>Simple product:</strong> select values to display on product page.<br>
                                <strong>Variable product:</strong> check <em>"Used for variations"</em> to create
                                variation combinations.
                              </div>

                              <% attrTypes.forEach(function(attrType) { %>
                                <% var taxonomy='pa_' + attrType.attribute_type_name; %>
                                  <% var existing=selAttrs[taxonomy]; %>
                                    <% var selIds=existing ? existing.value_ids : []; %>
                                      <% var isVariation=existing ? !!existing.is_variation : false; %>

                                        <div class="card border mb-3 attribute-block"
                                          data-type-id="<%= attrType.attribute_type_id %>"
                                          data-taxonomy="<%= attrType.attribute_type_name %>"
                                          data-label="<%= attrType.attribute_type_label %>">

                                          <div
                                            class="card-header d-flex justify-content-between align-items-center py-2">
                                            <div class="d-flex align-items-center gap-2">
                                              <span class="badge bg-primary rounded-pill">
                                                <%= attrType.attribute_type_label %>
                                              </span>
                                              <small class="text-muted">pa_<%= attrType.attribute_type_name %></small>
                                              <% if (selIds.length> 0) { %>
                                                <span class="badge bg-success rounded-pill" style="font-size:10px;">
                                                  <%= selIds.length %> selected
                                                </span>
                                                <% } %>
                                            </div>
                                            <div class="d-flex align-items-center gap-3">
                                              <div class="form-check form-switch mb-0">
                                                <input class="form-check-input" type="checkbox"
                                                  id="vis_<%= attrType.attribute_type_id %>" name="attr_visible[]"
                                                  value="1" <%=selIds.length> 0 ? 'checked' : '' %> />
                                                <label class="form-check-label small"
                                                  for="vis_<%= attrType.attribute_type_id %>">Visible on page</label>
                                              </div>
                                              <div class="form-check form-switch mb-0 variation-only-toggle"
                                                style="display:none;">
                                                <input class="form-check-input variation-toggle" type="checkbox"
                                                  id="varToggle_<%= attrType.attribute_type_id %>"
                                                  name="attr_for_variation[]" value="1" <%=isVariation ? 'checked' : ''
                                                  %>
                                                onchange="onVariationToggle()" />
                                                <label class="form-check-label small fw-bold text-primary"
                                                  for="varToggle_<%= attrType.attribute_type_id %>">Used for
                                                  variations</label>
                                              </div>
                                            </div>
                                          </div>

                                          <div class="card-body py-3">
                                            <input type="hidden" name="selected_attr_type[]"
                                              value="<%= attrType.attribute_type_id %>" />
                                            <input type="hidden" name="selected_attr_values[]"
                                              id="attrVals_<%= attrType.attribute_type_id %>"
                                              value="<%= selIds.join(',') %>" />

                                            <!-- TAG BOX -->
                                            <div
                                              class="attr-tagbox border rounded p-2 mb-2 d-flex flex-wrap gap-1 align-items-center"
                                              id="tagBox_<%= attrType.attribute_type_id %>"
                                              style="min-height:42px; cursor:text;"
                                              onclick="openAttrDropdown('<%= attrType.attribute_type_id %>')">

                                              <% attrType.values.forEach(function(val) { %>
                                                <% if (selIds.includes(String(val.attr_id))) { %>
                                                  <span
                                                    class="attr-tag d-inline-flex align-items-center gap-1 px-2 py-1 rounded"
                                                    style="background:#e8f0fe; border:1px solid #22311d; font-size:13px;"
                                                    id="tag_<%= attrType.attribute_type_id %>_<%= val.attr_id %>">
                                                    <%= val.attr_name %>
                                                      <button type="button" class="btn-close p-0 ms-1"
                                                        style="font-size:9px;"
                                                        onclick="event.stopPropagation(); removeAttrTag('<%= attrType.attribute_type_id %>', '<%= val.attr_id %>', '<%= val.attr_name %>')">
                                                      </button>
                                                  </span>
                                                  <% } %>
                                                    <% }) %>

                                                      <% attrType.values.forEach(function(val) { %>
                                                        <% var isSel=selIds.includes(String(val.attr_id)); %>
                                                          <input type="checkbox" class="d-none attr-value-cb"
                                                            id="cb_<%= attrType.attribute_type_id %>_<%= val.attr_id %>"
                                                            data-type-id="<%= attrType.attribute_type_id %>"
                                                            data-attr-id="<%= val.attr_id %>"
                                                            data-attr-name="<%= val.attr_name %>"
                                                            data-attr-slug="<%= val.attr_slug %>"
                                                            data-taxonomy="<%= attrType.attribute_type_name %>"
                                                            value="<%= val.attr_id %>" <%=isSel ? 'checked' : '' %> />
                                                          <% }) %>
                                            </div>

                                            <!-- Dropdown -->
                                            <div id="attrDropdown_<%= attrType.attribute_type_id %>"
                                              class="border rounded bg-white shadow-sm mb-2"
                                              style="display:none; max-height:220px; overflow-y:auto;">
                                              <div class="px-2 pt-2 pb-1 border-bottom bg-white"
                                                style="position:sticky;top:0;">
                                                <input type="text" id="attrSearch_<%= attrType.attribute_type_id %>"
                                                  class="form-control form-control-sm"
                                                  placeholder="Search <%= attrType.attribute_type_label %>..."
                                                  oninput="filterAttrList('<%= attrType.attribute_type_id %>', this.value)"
                                                  onclick="event.stopPropagation()" />
                                              </div>
                                              <ul class="list-unstyled mb-0"
                                                id="attrList_<%= attrType.attribute_type_id %>">
                                                <% attrType.values.forEach(function(val) { %>
                                                  <li class="px-3 py-2 d-flex align-items-center gap-2"
                                                    style="cursor:pointer; font-size:13px;"
                                                    data-name="<%= val.attr_name.toLowerCase() %>"
                                                    onmouseover="this.style.background='#f0f4ff'"
                                                    onmouseout="this.style.background=''"
                                                    onclick="toggleAttrTag('<%= attrType.attribute_type_id %>', '<%= val.attr_id %>', '<%= val.attr_name %>', '<%= val.attr_slug %>')">
                                                    <span
                                                      id="listCheck_<%= attrType.attribute_type_id %>_<%= val.attr_id %>"
                                                      class="text-primary fw-bold"
                                                      style="width:14px;display:inline-block;">
                                                      <%= selIds.includes(String(val.attr_id)) ? '✓' : '' %>
                                                    </span>
                                                    <%= val.attr_name %>
                                                  </li>
                                                  <% }) %>
                                              </ul>
                                              <div class="border-top px-3 py-2 d-flex gap-2 bg-white">
                                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                                  onclick="selectAllAttr('<%= attrType.attribute_type_id %>')">Select
                                                  all</button>
                                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                                  onclick="clearAllAttr('<%= attrType.attribute_type_id %>')">Select
                                                  none</button>
                                                <button type="button" class="btn btn-sm btn-link ms-auto text-muted"
                                                  onclick="document.getElementById('attrDropdown_<%= attrType.attribute_type_id %>').style.display='none'">
                                                  Close ✕
                                                </button>
                                              </div>
                                            </div>

                                          </div>
                                        </div>
                                        <% }) %>
                            </div>
                            <!-- /tab-attributes -->

                            <!-- VARIATIONS TAB -->
                            <div class="tab-pane fade" id="tab-variations">
                              <div class="d-flex justify-content-between align-items-center mb-3">
                                <p class="text-muted mb-0 small">Each variation can have its own price, stock and SKU.
                                </p>
                                <div class="d-flex gap-2">
                                  <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill"
                                    onclick="toggleAllVariations(true)">
                                    <i data-feather="chevrons-down" class="feather-sm"></i> Expand All
                                  </button>
                                  <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill"
                                    onclick="toggleAllVariations(false)">
                                    <i data-feather="chevrons-up" class="feather-sm"></i> Collapse All
                                  </button>
                                </div>
                              </div>

                              <div id="variationsList">
                                <% if (varList.length> 0) { %>
                                  <% varList.forEach(function(v, i) { %>
                                    <% var attrLabel=Object.entries(v.attr_meta || {}).map(function(entry) { return
                                      entry[1].split('-').map(function(w) { return w.charAt(0).toUpperCase() +
                                      w.slice(1); }).join(' ');
                                    }).join(' / '); %>
                                    <% var comboEntries = Object.entries(v.attr_meta || {}); %>
                                    <% var vEnabled = v.enabled !== ' no'; %>

                                      <div class="variation-item border rounded mb-2">
                                        <!-- Header -->
                                        <div
                                          class="variation-header d-flex justify-content-between align-items-center px-3 py-2 bg-light rounded-top"
                                          style="cursor:pointer;" onclick="toggleVariation(this)">
                                          <div class="d-flex align-items-center gap-2 flex-wrap">
                                            <i data-feather="chevron-right"
                                              class="feather-sm variation-chevron text-muted"
                                              style="transition:transform 0.2s;"></i>
                                            <strong class="small text-primary variation-label">
                                              <%= attrLabel || ('Variation #' + (i + 1)) %>
                                            </strong>
                                            <% if (v.sku) { %>
                                              <span class="badge bg-light border text-muted"
                                                style="font-size:10px;">SKU: <%= v.sku %></span>
                                              <% } %>
                                                <% if (v.regular_price || v.price) { %>
                                                  <span class="badge bg-primary" style="font-size:10px;">₹<%=
                                                      v.regular_price || v.price %></span>
                                                  <% } %>
                                                    <span
                                                      class="badge <%= v.stock_status === 'instock' ? 'bg-success' : 'bg-danger' %>"
                                                      style="font-size:10px;">
                                                      <%= v.stock_status==='instock' ? 'In Stock' :
                                                        v.stock_status==='outofstock' ? 'Out of Stock' : 'Backorder' %>
                                                    </span>
                                          </div>
                                          <button type="button" class="btn btn-sm btn-outline-danger"
                                            style="padding:2px 8px;"
                                            onclick="event.stopPropagation(); this.closest('.variation-item').remove()">
                                            <i data-feather="x" class="feather-sm"></i>
                                          </button>
                                        </div>

                                        <!-- Body -->
                                        <div class="variation-body border-top" style="display:none;">
                                          <input type="hidden" name="var_attr_combo[]" value="<%= v.combo %>" />
                                          <input type="hidden" name="var_attr_ids[]" value="<%= v.attr_ids %>" />
                                          <input type="hidden" name="var_product_id[]" value="<%= v.ID %>" />

                                          <!-- Attribute dropdowns -->
                                          <% if (comboEntries.length> 0) { %>
                                            <div
                                              class="d-flex flex-wrap gap-3 align-items-end px-3 py-2 border-bottom bg-white">
                                              <% comboEntries.forEach(function(entry) { %>
                                                <% var metaKey=entry[0]; %>
                                                  <% var metaVal=entry[1]; %>
                                                    <% var taxName=metaKey.replace('attribute_pa_', '' ); %>
                                                      <% var atType=attrTypes.find(function(t) { return
                                                        t.attribute_type_name===taxName; }); %>
                                                        <div style="min-width:160px;">
                                                          <label class="form-label small fw-semibold mb-1">
                                                            <%= atType ? atType.attribute_type_label : taxName %>
                                                          </label>
                                                          <select class="form-select form-select-sm var-attr-select"
                                                            data-combo-key="pa_<%= taxName %>"
                                                            onchange="updateVariationCombo(this)">
                                                            <option value="">Any <%= atType ?
                                                                atType.attribute_type_label : taxName %>…</option>
                                                            <% if (atType && atType.values) { %>
                                                              <% atType.values.forEach(function(val) { %>
                                                                <option value="<%= val.attr_slug %>"
                                                                  data-attr-id="<%= val.attr_id %>"
                                                                  <%=(metaVal===val.attr_slug) ? 'selected' : '' %>>
                                                                  <%= val.attr_name %>
                                                                </option>
                                                                <% }) %>
                                                                  <% } %>
                                                          </select>
                                                        </div>
                                                        <% }) %>
                                            </div>
                                            <% } %>

                                              <!-- 2-column layout -->
                                              <div class="row g-0">
                                                <div class="col-md-6 p-3 border-end">
                                                  <div class="mb-3">
                                                    <label class="form-label small fw-semibold">SKU</label>
                                                    <input type="text" name="var_sku[]"
                                                      class="form-control form-control-sm" value="<%= v.sku || '' %>"
                                                      placeholder="Variation SKU" />
                                                  </div>
                                                  <div class="mb-3">
                                                    <label class="form-label small fw-semibold">Regular Price
                                                      (₹)</label>
                                                    <div class="input-group input-group-sm">
                                                      <span class="input-group-text">₹</span>
                                                      <input type="number" name="var_regular_price[]"
                                                        class="form-control"
                                                        value="<%= v.regular_price || v.price || '' %>"
                                                        placeholder="0.00" step="0.01" />
                                                    </div>
                                                  </div>
                                                  <div class="mb-3">
                                                    <label class="form-label small fw-semibold">Sale Price (₹)</label>
                                                    <div class="input-group input-group-sm">
                                                      <span class="input-group-text">₹</span>
                                                      <input type="number" name="var_sale_price[]" class="form-control"
                                                        value="<%= v.sale_price || '' %>" placeholder="0.00"
                                                        step="0.01" />
                                                    </div>
                                                  </div>
                                                  <div class="mb-3">
                                                    <label class="form-label small fw-semibold">Stock Status</label>
                                                    <select name="var_stock_status[]"
                                                      class="form-select form-select-sm">
                                                      <option value="instock" <%=v.stock_status==='instock' ? 'selected'
                                                        : '' %>>In Stock</option>
                                                      <option value="outofstock" <%=v.stock_status==='outofstock'
                                                        ? 'selected' : '' %>>Out of Stock</option>
                                                      <option value="onbackorder" <%=v.stock_status==='onbackorder'
                                                        ? 'selected' : '' %>>On Backorder</option>
                                                    </select>
                                                  </div>
                                                  <div class="mb-3">
                                                    <label class="form-label small fw-semibold">Stock Qty</label>
                                                    <input type="number" name="var_stock[]"
                                                      class="form-control form-control-sm" value="<%= v.stock || '0' %>"
                                                      min="0" />
                                                  </div>
                                                </div>

                                                <div class="col-md-6 p-3">
                                                  <div class="mb-3">
                                                    <label class="form-label small fw-semibold">Variation
                                                      Description</label>
                                                    <textarea name="var_description[]"
                                                      class="form-control form-control-sm" rows="3"
                                                      placeholder="Optional description..."><%= v.variation_description || '' %></textarea>
                                                  </div>

                                                  <!-- Variation Image -->
                                                  <div class="mb-3">
                                                    <label class="form-label small fw-semibold d-block">Variation
                                                      Image</label>
                                                    <div id="varImagePreview_<%= v.ID %>"
                                                      class="border rounded p-2 text-center mb-2"
                                                      style="min-height:90px; cursor:pointer;" onclick="openMedia({
                                                  urlInput:   'var_featured_image_<%= v.ID %>',
                                                  titleInput: 'var_featured_image_title_<%= v.ID %>',
                                                  altInput:   'var_featured_image_alt_<%= v.ID %>',
                                                  preview:    'varImagePreview_<%= v.ID %>',
                                                  multiple:   false
                                                })">
                                                      <% if (v.thumbnail_url) { %>
                                                        <img src="<%= v.thumbnail_url %>"
                                                          class="img-fluid rounded selectedVarFeaturedImage"
                                                          style="max-height:80px;" />
                                                        <% } else { %>
                                                          <i data-feather="image" class="text-muted"></i>
                                                          <p class="text-muted small mb-0 mt-1">Click to select</p>
                                                          <% } %>
                                                    </div>

                                                    <% if (v.thumbnail_url) { %>

                                                      <button type="button" data-id="<%= v.ID %>"
                                                        class="btn btn-link btn-sm text-danger p-0 removeVarFeaturedImagebtn">
                                                        <i data-feather="trash-2" class="feather-sm me-1"></i> Remove
                                                        featured image
                                                      </button>

                                                      <% } %>
