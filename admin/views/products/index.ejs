<%- include('../partials/head') %>


  <%- include('../partials/navbar') %>

    <%- include('../partials/sidebar') %>

      <div class="page-wrapper">
        <!-- Breadcrumb -->
        <div class="page-breadcrumb">
          <div class="row">
            <div class="col-7 align-self-center">
              <h4 class="page-title">Products</h4>
              <div class="d-flex align-items-center">
                <nav aria-label="breadcrumb">
                  <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/admin/dashboard">Home</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Products</li>
                  </ol>
                </nav>
              </div>
            </div>
            <div class="col-5 align-self-center text-end">
              <a href="/admin/products/add" class="btn-view-product btn-view-product--inline na-view-all-btn">
                <div class="d-flex align-items-center">
                  <i data-feather="plus" class="feather-sm me-1"></i>
                  Add Product
                </div>
              </a>
            </div>
          </div>
        </div>

        <div class="container-fluid">

          <% if (typeof error !=='undefined' && error) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
              <i data-feather="alert-circle" class="feather-sm me-1"></i>
              <%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            <% } %>

              <div class="row">
                <div class="col-12">
                  <div class="card">
                    <div class="card-body">


                      <div class="table-responsive">
                        <table id="productsTable" class="table table-hover table-striped align-middle">
                          <thead class="table-dark">
                            <tr>
                              <th width="50">
                                <div class="form-check">
                                  <input class="form-check-input" type="checkbox" id="selectAll" />
                                </div>
                              </th>
                              <th width="70">Image</th>
                              <th>Product Name</th>
                              <th>Price</th>
                              <th>Status</th>
                              <th>Date</th>
                              <th width="120">Actions</th>
                            </tr>
                          </thead>
                          <tbody>
                            <% if (products && products.length> 0) { %>
                              <% products.forEach(function(product) { %>
                                <tr>
                                  <td>
                                    <div class="form-check">
                                      <input class="form-check-input product-checkbox" type="checkbox"
                                        value="<%= product.ID %>" />
                                    </div>
                                  </td>
                                  <td>
                                    <% if (product.thumbnail) { %>
                                      <img src="<%= product.thumbnail %>" alt="<%= product.product_title %>"
                                        class="rounded" width="50" height="50" style="object-fit:cover;" />
                                      <% } else { %>
                                        <div class="bg-light rounded d-flex align-items-center justify-content-center"
                                          style="width:50px;height:50px;">
                                          <i data-feather="image" class="text-muted feather-sm"></i>
                                        </div>
                                        <% } %>
                                  </td>
                                  <td>
                                    <div class="d-flex flex-column gap-1">

                                      <!-- Title -->
                                      <strong class="text-dark">
                                        <%= product.product_title %>
                                      </strong>

                                      <!-- Variation -->
                                      <% if (product.parent_id> 0) { %>
                                        <small class="text-muted">
                                          Variation of #<%= product.parent_id %>
                                        </small>
                                        <% } %>

                                          <!-- SKU -->
                                          <small class="text-secondary">
                                            SKU: <%= product.sku || '—' %>
                                          </small>

                                          <!-- Stock Status -->
                                          <div>
                                            <% if (product.stock_status==='instock' ) { %>
                                              <span class="badge bg-success-subtle text-success">
                                                In Stock (<%= product.stock || 0 %>)
                                              </span>
                                              <% } else if (product.stock_status==='outofstock' ) { %>
                                                <span class="badge bg-danger-subtle text-danger">
                                                  Out of Stock
                                                </span>
                                                <% } else { %>
                                                  <span class="badge bg-warning-subtle text-warning">
                                                    Backorder
                                                  </span>
                                                  <% } %>
                                          </div>

                                    </div>
                                  </td>
                                  <td>
                                    <% if (product.sale_price) { %>
                                      <span class="text-decoration-line-through text-muted">₹<%= product.regular_price
                                          %></span>
                                      <span class="text-success ms-1">₹<%= product.sale_price %></span>
                                      <% } else { %>
                                        <span>₹<%= product.regular_price || '—' %></span>
                                        <% } %>
                                  </td>
                                  <td>
                                    <% if (product.product_status==='publish' ) { %>
                                      <span class="badge bg-success">Published</span>
                                      <% } else if (product.product_status==='draft' ) { %>
                                        <span class="badge bg-secondary">Draft</span>
                                        <% } else { %>
                                          <span class="badge bg-danger">Trash</span>
                                          <% } %>
                                  </td>
                                  <td>
                                    <small class="text-muted">
                                      <%= new Date(product.product_date_added).toLocaleDateString('en-IN') %>
                                    </small>
                                  </td>
                                  <td>
                                    <div class="d-flex gap-1">
                                      <a href="/admin/products/edit/<%= product.ID %>"
                                        class="btn btn-sm btn-light-primary text-primary" title="Edit">
                                        <i data-feather="edit-2" class="feather-sm"></i>
                                      </a>
                                      <button class="btn btn-sm btn-light-danger text-danger delete-btn"
                                        data-id="<%= product.ID %>" data-name="<%= product.product_title %>"
                                        data-url="/admin/products/delete/" data-title="Delete Product">
                                        <i data-feather="trash-2" class="feather-sm"></i>
                                      </button>
                                    </div>
                                  </td>
                                </tr>
                                <% }) %>
                                  <% } else { %>
                                    <tr>
                                      <td colspan="10" class="text-center py-5">
                                        <i data-feather="package" style="width:48px;height:48px;"
                                          class="text-muted mb-3 d-block mx-auto"></i>
                                        <h5 class="text-muted">No products found</h5>
                                        <a href="/admin/products/add"
                                          class="btn btn-primary rounded-pill mt-2">Add Your First Product</a>
                                      </td>
                                    </tr>
                                    <% } %>
                          </tbody>
                        </table>
                      </div>


                    </div>
                  </div>
                </div>
              </div>
        </div>

      </div>
      </div>



      <%- include('../partials/scripts') %>
        <script>


          $(document).ready(function () {
            $('#productsTable').DataTable({
              "responsive": true,
              "autoWidth": false,
              "order": [[0, "desc"]],
              "pageLength": 10,
              "columnDefs": [
                { "orderable": false, "targets": 6 }
              ],
              "language": {
                "emptyTable": "No pages found",
                "info": "Showing _START_ to _END_ of _TOTAL_ pages",
                "infoEmpty": "Showing 0 to 0 of 0 pages",
                "search": "Search pages:",
                "paginate": {
                  "first": "First",
                  "last": "Last",
                  "next": "Next",
                  "previous": "Previous"
                }
              }
            });
          });


          // Select all checkbox
          document.getElementById('selectAll').addEventListener('change', function () {
            document.querySelectorAll('.product-checkbox').forEach(cb => cb.checked = this.checked);
          });


          feather.replace();

        </script>

        <%- include('../partials/footer') %>