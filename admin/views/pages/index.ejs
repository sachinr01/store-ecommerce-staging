<%- include('../partials/head') %>

  <%- include('../partials/navbar') %>
    <%- include('../partials/sidebar') %>

      <div class="page-wrapper">

        <div class="page-breadcrumb">
          <div class="row">
            <div class="col-7 align-self-center">
              <h4 class="page-title">
                Pages
              </h4>
              <div class="d-flex align-items-center">
                <nav aria-label="breadcrumb">
                  <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/admin/dashboard">Home</a></li>
                    <li class="breadcrumb-item active">Pages</li>
                  </ol>
                </nav>
              </div>
            </div>
            <div class="col-5 align-self-center text-end">
              <a href="/admin/pages/add" class="btn-view-product btn-view-product--inline na-view-all-btn">
                <div class="d-flex align-items-center">
                  <i data-feather="plus" class="feather-sm me-1"></i> Add Page
                </div>
              </a>
            </div>
          </div>
        </div>

        <div class="container-fluid">

          <div class="card">
            <div class="card-body">

              <div class="table-responsive">
                <table id="pagesTable" class="table table-hover">
                  <thead>
                    <tr>
                      <th>ID</th>
                      <th>Title</th>
                      <th>Type</th>
                      <th>Status</th>
                      <th>Published Date</th>
                      <th>Order</th>
                      <th width="150">Action</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (pages && pages.length) { %>
                      <% pages.forEach(p=> { %>
                        <tr>
                          <td><span class="badge bg-light text-dark">
                              <%= p.ID %>
                            </span></td>
                          <td><strong>
                              <%= p.post_title %>
                            </strong></td>
                          <td>
                            <span class="badge bg-info">
                              <%= p.post_type==='page' ? 'Page' : 'Post' %>
                            </span>
                          </td>
                          <td>
                            <span class="badge bg-<%= p.post_status === 'publish' ? 'success' : 'warning' %>">
                              <%= p.post_status==='publish' ? 'Published' : 'Draft' %>
                            </span>
                          </td>
                          <td>
                            <small class="text-muted">
                              <%= new Date(p.post_date).toLocaleDateString('en-US', { year: 'numeric' , month: 'short' ,
                                day: 'numeric' }) %>
                            </small>
                          </td>
                          <td>
                            <%= p.menu_order || 0 %>
                          </td>
                          <td>
                            <div class="d-flex gap-1">
                              <a href="/admin/pages/edit/<%= p.ID %>" class="btn btn-sm btn-warning" title="Edit">
                                <i data-feather="edit-2" class="feather-sm"></i>
                              </a>
                              <button class="btn btn-sm btn-danger delete-btn" data-id="<%= p.ID %>"
                                data-name="Page ID <%= p.ID %>" data-url="/admin/pages/delete/"
                                data-title="Delete Page" title="Delete">

                                <i data-feather="trash-2" class="feather-sm"></i>
                              </button>
                            </div>
                          </td>
                        </tr>
                        <% }) %>
                          <% } else { %>
                            <tr>
                              <td colspan="7" class="text-center py-5">
                                <div>
                                  <i data-feather="inbox" style="width:48px;height:48px;"
                                    class="text-muted mb-3 d-block mx-auto"></i>
                                  <p class="text-muted">No pages found</p>
                                  <a href="/admin/pages/add" class="btn btn-sm btn-primary">
                                    Create First Page
                                  </a>
                                </div>
                              </td>
                            </tr>
                            <% } %>
                  </tbody>
                </table>
              </div>

            </div>
          </div>

        </div>
      </div>

      <%- include('../partials/scripts') %>


        <script>
          $(document).ready(function () {
            $('#pagesTable').DataTable({
              "responsive": true,
              "autoWidth": false,
              "order": [[0, "desc"]],
              "pageLength": 10,
              "columnDefs": [
                { "orderable": false, "targets": 6 }
              ],
              "language": {
                "emptyTable": "No pages found",
                "info": "Showing _START_ to _END_ of _TOTAL_ pages",
                "infoEmpty": "Showing 0 to 0 of 0 pages",
                "search": "Search pages:",
                "paginate": {
                  "first": "First",
                  "last": "Last",
                  "next": "Next",
                  "previous": "Previous"
                }
              }
            });
          });

          feather.replace();
        </script>


        <%- include('../partials/footer') %>