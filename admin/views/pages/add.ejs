<%- include('../partials/head') %>

  <% var b=locals.page || null; var isEdit=locals.isEdit; %>

    <%- include('../partials/navbar') %>
      <%- include('../partials/sidebar') %>

        <div class="page-wrapper">

          <div class="page-breadcrumb">
            <div class="row">
              <div class="col-7 align-self-center">
                <h4 class="page-title">
                  <%= isEdit ? 'Edit Page' : 'Add Page' %>
                </h4>
                <div class="d-flex align-items-center">
                  <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                      <li class="breadcrumb-item"><a href="/admin/dashboard">Home</a></li>
                      <li class="breadcrumb-item"><a href="/admin/pages">Pages</a></li>
                      <li class="breadcrumb-item active">
                        <%= isEdit ? 'Edit' : 'Add' %>
                      </li>
                    </ol>
                  </nav>
                </div>
              </div>
              <div class="col-5 align-self-center text-end">
                <a href="/admin/pages" class="btn-view-product btn-view-product--inline na-view-all-btn"
                  title="Back to Pages">
                  <div class=" align-items-center">
                    <i data-feather="arrow-left" class="feather-sm me-1"></i> Back to Pages
                  </div>
                </a>
                <% if (isEdit) { %>
                  <!-- View page -->
                  <a href="/<%= page.post_slug %>" target="_blank"
                    class="btn-view-second btn-view-second--inline na-view-all-btn" title="View Page">
                    <div class="align-items-center gap-2">
                      View Page <i data-feather="external-link" class=" feather-sm"></i>
                    </div>
                  </a>
                  <% } %>
              </div>
            </div>
          </div>

          <div class="container-fluid">

            <% if (locals.errors) { %>
              <div class="alert alert-danger alert-dismissible fade show">
                <i data-feather="alert-circle" class="feather-sm me-1"></i>
                <%= locals.errors %>
                  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
              </div>
              <% } %>

                <form action="<%= isEdit ? '/admin/pages/update/' + b.ID : '/admin/pages' %>"
                  method="POST">

                  <div class="row">

                    <!-- LEFT COLUMN -->
                    <div class="col-lg-8">

                      <div class="card mb-3">
                        <div class="card-body">
                          <h4 class="card-title mb-3 pb-3 border-bottom">Page Content</h4>

                          <div class="mb-3">
                            <label class="form-label fw-semibold">Page Title <span class="text-danger">*</span></label>
                            <input type="text" name="post_title" class="form-control form-control-lg"
                              placeholder="Enter page title..." value="<%= isEdit ? b.post_title : '' %>" required />
                          </div>

                          <div class="mb-3">
                            <label class="form-label fw-semibold">Page URL (Slug)</label>
                            <div class="input-group">
                              <span class="input-group-text text-muted">/page/</span>
                              <input type="text" name="post_slug" id="postSlug" class="form-control"
                                placeholder="auto-generated-slug" value="<%= isEdit ? b.post_slug : '' %>" />
                            </div>
                            <small class="text-muted">Auto-generated from title if left empty</small>
                          </div>

                          <div class="mb-3">
                            <label class="form-label fw-semibold">Short Description</label>
                            <textarea name="post_short_desc" id="post_short_desc" class="form-control" rows="3"
                              placeholder="Brief page description..."><%= isEdit ? (b.post_short_desc || '') : '' %></textarea>
                          </div>

                          <div class="mb-3">
                            <label class="form-label fw-semibold">Full Content</label>
                            <textarea name="post_content" class="form-control" rows="10"
                              placeholder="Detailed blog content..."
                              id="editor"><%= isEdit ? (b.post_content || '') : '' %></textarea>
                          </div>
                        </div>
                      </div>

                      <!-- SEO CARD -->
                      <div class="card mb-3">
                        <div class="card-body">
                          <h4 class="card-title mb-3 pb-3 border-bottom">SEO Settings</h4>

                          <!-- Meta Title -->
                          <div class="mb-3">
                            <label class="form-label fw-semibold">Meta Title</label>
                            <input type="text" name="meta_title" class="form-control"
                              placeholder="SEO title for search engines"
                              value="<%= isEdit ? (b.meta_title || '') : '' %>" />
                            <small class="text-muted">Recommended: 50–60 characters</small>
                          </div>

                          <!-- Meta Description -->
                          <div class="mb-3">
                            <label class="form-label fw-semibold">Meta Description</label>
                            <textarea name="meta_description" class="form-control" rows="3"
                              placeholder="Short SEO description for search engines"><%= isEdit ? (b.meta_description || '') : '' %></textarea>
                            <small class="text-muted">Recommended: 150–160 characters</small>
                          </div>

                          <!-- Canonical URL -->
                          <div class="mb-3">
                            <label class="form-label fw-semibold">Canonical URL</label>
                            <input type="text" name="canonical_tag" class="form-control"
                              placeholder="https://example.com/blog-url"
                              value="<%= isEdit ? (b.canonical_tag || '') : '' %>" />
                          </div>

                          <!-- Index -->
                          <div class="mb-0">
                            <label class="form-label fw-semibold d-block">Index</label>

                            <div class="form-check form-check-inline">
                              <input class="form-check-input" type="radio" name="meta_index" id="indexYes" value="yes"
                                <%=!isEdit || b.meta_index==='yes' || !b.meta_index ? 'checked' : '' %>>
                              <label class="form-check-label" for="indexYes">
                                Yes
                              </label>
                            </div>

                            <div class="form-check form-check-inline">
                              <input class="form-check-input" type="radio" name="meta_index" id="indexNo" value="no"
                                <%=isEdit && b.meta_index==='no' ? 'checked' : '' %>>
                              <label class="form-check-label" for="indexNo">
                                No
                              </label>
                            </div>
                          </div>
                        </div>
                      </div>

                    </div><!-- /col-lg-8 -->

                    <!-- RIGHT COLUMN -->
                    <div class="col-lg-4">

                      <!-- PUBLISH CARD -->
                      <div class="card mb-3">
                        <div class="card-body">
                          <h4 class="card-title mb-3 pb-3 border-bottom">Publish</h4>

                          <div class="mb-3">
                            <label class="form-label fw-semibold">Status</label>
                            <select name="post_status" class="form-select">
                              <option value="publish" <%=(!isEdit || b.post_status==='publish' ) ? 'selected' : '' %>
                                >Published</option>
                              <option value="draft" <%=(isEdit && b.post_status==='draft' ) ? 'selected' : '' %>>Draft
                              </option>
                            </select>
                          </div>

                          <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary rounded-pill">
                              <%= isEdit ? 'Update Page' : 'Publish Page' %>
                            </button>
                            <a href="/admin/pages" class="btn btn-outline-secondary rounded-pill">
                              Cancel
                            </a>
                          </div>
                        </div>
                      </div>




                      <!-- POST SETTINGS CARD -->
                      <div class="card mb-3">
                        <div class="card-body">
                          <h4 class="card-title mb-3 pb-3 border-bottom">Post Settings</h4>

                          <input type="hidden" name="post_type" value="page">


                          <div class="mb-3">
                            <label class="form-label fw-semibold">Menu Order</label>
                            <input type="number" name="menu_order" class="form-control" placeholder="0"
                              value="<%= isEdit ? (b.menu_order || 0) : 0 %>" min="0" />
                            <small class="text-muted">Lower number = shown first</small>
                          </div>

                          <div class="mb-3">
                            <label class="form-label fw-semibold">Published Date</label>
                            <% let publishValue=new Date(); if (isEdit && b.post_date) { const d=new Date(b.post_date);
                              if (!isNaN(d.getTime())) { publishValue=d; } } %>

                              <input type="datetime-local" name="post_date" class="form-control"
                                value="<%= publishValue.toISOString().slice(0,16) %>" />
                          </div>

                          <div class="mb-3">
                            <label class="form-label fw-semibold">Modified Date</label>
                            <% let modifiedValue=new Date(); if (isEdit && b.post_modified) { const d=new
                              Date(b.post_modified); if (!isNaN(d.getTime())) { modifiedValue=d; } } %>

                              <input type="datetime-local" name="post_modified" class="form-control"
                                value="<%= modifiedValue.toISOString().slice(0,16) %>" disabled />
                              <small class="text-muted">Auto-updated on save</small>
                          </div>
                        </div>
                      </div>

                    </div><!-- /col-lg-4 -->

                  </div><!-- /row -->
                </form>

          </div>
        </div>


        <%- include('../partials/scripts') %>


          <script>
            ClassicEditor.create(document.querySelector('#editor')).catch(error => console.error(error));
            ClassicEditor.create(document.querySelector('#post_short_desc')).catch(error => console.error(error));

            // Auto-generate slug from title
            document.querySelector('[name="post_title"]').addEventListener('input', function () {
              var urlField = document.getElementById('postSlug');
              if (!urlField.dataset.manual) {
                urlField.value = this.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
              }
            });

            // Mark slug as manually edited
            document.getElementById('postSlug').addEventListener('input', function () {
              this.dataset.manual = '1';
            });

            feather.replace();

            document.addEventListener("click", function (e) {
              if (e.target.closest("#removeBlogImagebtn")) {

                // 🔥 Clear preview
                const preview = document.getElementById("blogImagePreview");
                preview.innerHTML = `
                  <div>
                    <i data-feather="image" style="width:48px;height:48px;" class="text-muted mb-2 d-block mx-auto"></i>
                    <p class="text-muted small mb-0">Click to select blog image</p>
                  </div>
                `;

                // 🔥 Clear inputs
                document.getElementById("blog_image").value = "";
                document.getElementById("blog_image_title").value = "";
                document.getElementById("blog_image_alt").value = "";

                // 🔥 Hide remove button
                e.target.closest("button").style.display = "none";

                // re-render feather icon
                if (window.feather) feather.replace();
              }
            });
          </script>


          <%- include('../partials/footer') %>