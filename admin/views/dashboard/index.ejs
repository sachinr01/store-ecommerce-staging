<%- include('../partials/head') %>
    <%- include('../partials/navbar') %>
        <%- include('../partials/sidebar') %>

            <div class="page-wrapper">

                <div class="page-breadcrumb">
                    <div class="row">
                        <div class="col-5 align-self-center">
                            <h4 class="page-title">Dashboard</h4>
                            <div class="d-flex align-items-center">
                                <nav aria-label="breadcrumb">
                                    <ol class="breadcrumb">
                                        <li class="breadcrumb-item"><a href="#">Home</a></li>
                                        <li class="breadcrumb-item active" aria-current="page">Dashboard</li>
                                    </ol>
                                </nav>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="container-fluid">

                    <% if (typeof success !=='undefined' && success) { %>
                        <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2"
                            role="alert">
                            <i data-feather="check-circle" class="feather-sm flex-shrink-0"></i>
                            <%= success %>
                                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                        </div>
                        <% } %>

                            <% if (typeof error !=='undefined' && error) { %>
                                <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2"
                                    role="alert">
                                    <i data-feather="alert-circle" class="feather-sm flex-shrink-0"></i>
                                    <%= error %>
                                        <button type="button" class="btn-close ms-auto"
                                            data-bs-dismiss="alert"></button>
                                </div>
                                <% } %>

                                    <!-- ===================== TOP STAT CARDS ===================== -->
                                    <div class="row mb-4">

                                        <div class="col-xl-3 col-md-3 mb-3">
                                            <div class="card border-0 rounded-4 shadow-sm bg-primary text-white h-100">
                                                <div
                                                    class="card-body d-flex justify-content-between align-items-center">
                                                    <div>
                                                        <h4 class="text-uppercase fw-semibold">Total Users</h4>
                                                        <h1 class="fw-bold mb-0">
                                                            <%= stats.totalUsers %>
                                                        </h1>
                                                    </div>
                                                    <i class="ri-user-3-line fs-7 opacity-50"></i>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-xl-3 col-md-3 mb-3">
                                            <div class="card border-0 rounded-4 shadow-sm bg-success text-white h-100">
                                                <div
                                                    class="card-body d-flex justify-content-between align-items-center">
                                                    <div>
                                                        <h4 class="text-uppercase fw-semibold">Total Orders
                                                        </h4>
                                                        <h1 class="fw-bold mb-0">
                                                            <%= stats.totalOrders %>
                                                        </h1>
                                                    </div>
                                                    <i class="ri-shopping-cart-line fs-7 opacity-50"></i>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-xl-3 col-md-3 mb-3">
                                            <div class="card border-0 rounded-4 shadow-sm bg-warning text-white h-100">
                                                <div
                                                    class="card-body d-flex justify-content-between align-items-center">
                                                    <div>
                                                        <h4 class="text-uppercase fw-semibold">Revenue</h4>
                                                        <h1 class="fw-bold mb-0">₹<%=
                                                                Number(stats.totalRevenue).toFixed(2) %>
                                                        </h1>
                                                    </div>
                                                    <i class="ri-money-rupee-circle-line fs-7 opacity-50"></i>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-xl-3 col-md-3 mb-3">
                                            <div class="card border-0 rounded-4 shadow-sm bg-danger text-white h-100">
                                                <div
                                                    class="card-body d-flex justify-content-between align-items-center">
                                                    <div>
                                                        <h4 class="text-uppercase fw-semibold">Active Users
                                                        </h4>
                                                        <h1 class="fw-bold mb-0">
                                                            <%= stats.activeUsers %>
                                                        </h1>
                                                    </div>
                                                    <i class="ri-user-follow-line fs-7 opacity-50"></i>
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                    <!-- end top cards -->

                                    <!-- ===================== DASHBOARD GRID ===================== -->
                                    <div class="row">

                                        <!-- ============ LOW STOCK ALERTS ============ -->
                                        <div class="col-xl-6 col-lg-6 mb-4">
                                            <div class="card border-0 rounded-4 shadow-sm h-100">
                                                <div class="card-body">
                                                    <div class="d-flex justify-content-between align-items-center mb-4">
                                                        <h4 class="card-title mb-0 fw-bold">Low Stock Alerts</h4>
                                                        <span class="badge bg-danger">Stock ≤ 5</span>
                                                    </div>

                                                    <div id="lowstock-list">
                                                        <% if (lowStockProducts.length> 0) { %>
                                                            <% lowStockProducts.forEach(product=> { %>
                                                                <div
                                                                    class="d-flex align-items-center gap-3 py-3 border-bottom">
                                                                    <div class="flex-shrink-0">
                                                                        <img src="<%= product.thumbnail || '/admin/public/images/placeholder.png' %>"
                                                                            alt="<%= product.product_title %>"
                                                                            width="50" height="50" class="rounded"
                                                                            style="object-fit:cover;">
                                                                    </div>
                                                                    <div class="flex-grow-1 overflow-hidden">
                                                                        <div
                                                                            class="fw-semibold text-dark text-truncate">
                                                                            <%= product.product_title %>
                                                                        </div>
                                                                        <small class="text-muted">Product ID: #<%=
                                                                                product.ID %></small>
                                                                    </div>
                                                                    <div>
                                                                        <span class="badge bg-danger">
                                                                            <%= product.stock %> Left
                                                                        </span>
                                                                    </div>
                                                                </div>
                                                                <% }) %>
                                                                    <% } else { %>
                                                                        <div class="text-center py-5 text-muted">
                                                                            <i class="ri-checkbox-circle-line fs-1"></i>
                                                                            <p class="mt-2 mb-0">No low stock products
                                                                            </p>
                                                                        </div>
                                                                        <% } %>
                                                    </div>

                                                    <div class="text-end mt-3">
                                                        <button class="btn btn-sm btn-light-danger"
                                                            id="btn-lowstock-more" data-offset="5"
                                                            data-endpoint="/admin/load-more/low-stock"
                                                            data-target="lowstock-list" data-type="lowstock"
                                                            onclick="loadMore(this)">
                                                            View More
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- ============ BEST SELLERS ============ -->
                                        <div class="col-xl-6 col-lg-6 mb-4">
                                            <div class="card border-0 rounded-4 shadow-sm h-100">

                                                <div class="card-body">

                                                    <div class="d-flex justify-content-between align-items-center mb-4">
                                                        <h4 class="card-title mb-0 fw-bold">
                                                            Best Sellers
                                                        </h4>

                                                        <span class="badge bg-success">
                                                            Top 5
                                                        </span>
                                                    </div>

                                                    <div id="bestsellers-list">

                                                        <% bestSellers.forEach((item, index)=> { %>

                                                            <div
                                                                class="d-flex align-items-center gap-3 py-3 border-bottom">

                                                                <!-- Product Image -->
                                                                <div class="flex-shrink-0 position-relative">

                                                                    <img src="<%= item.thumbnail || '/admin/public/images/placeholder.png' %>"
                                                                        alt="<%= item.title %>" class="rounded"
                                                                        width="55" height="55"
                                                                        style="object-fit: cover;">

                                                                    <span
                                                                        class="badge bg-success position-absolute bottom-0 end-0 translate-middle-y"
                                                                        style="font-size:10px;">
                                                                        #<%= index + 1 %>
                                                                    </span>

                                                                </div>

                                                                <!-- Product Info -->
                                                                <div class="flex-grow-1 overflow-hidden">

                                                                    <div class="fw-semibold text-dark text-truncate">

                                                                        <a href="/product/<%= item.slug %>"
                                                                            class="text-decoration-none text-dark">
                                                                            <%= item.title %>
                                                                        </a>

                                                                    </div>

                                                                    <small class="text-muted d-block">

                                                                        <i class="ri-shopping-bag-line"></i>

                                                                        <%= item.totalSold %> sold

                                                                    </small>

                                                                    <small class="text-success fw-semibold">

                                                                        ₹<%= Number(item.price || 0).toFixed(2) %>

                                                                    </small>

                                                                </div>

                                                                <!-- Right Badge -->
                                                                <div class="text-end">

                                                                    <span
                                                                        class="badge bg-success bg-opacity-10 text-success fw-bold fs-6 px-3 py-2">
                                                                        <%= item.totalSold %>
                                                                    </span>

                                                                </div>

                                                            </div>

                                                            <% }) %>

                                                    </div>

                                                    <!-- Load More -->
                                                    <div class="text-end mt-3">

                                                        <button class="btn btn-sm btn-light-primary"
                                                            id="btn-bestsellers-more" data-offset="5"
                                                            data-endpoint="/admin/load-more/best-sellers"
                                                            data-target="bestsellers-list" data-type="bestsellers"
                                                            onclick="loadMore(this)">
                                                            View More
                                                        </button>

                                                    </div>

                                                </div>

                                            </div>
                                        </div>

                                        <!-- ============ LATEST ORDERS ============ -->
                                        <div class="col-xl-4 col-lg-4 mb-4">
                                            <div class="card border-0 rounded-4 shadow-sm h-100">
                                                <div class="card-body">
                                                    <div class="d-flex justify-content-between align-items-center mb-4">
                                                        <h4 class="card-title mb-0 fw-bold">Latest Orders</h4>
                                                        <span class="badge bg-info">Recent</span>
                                                    </div>

                                                    <div id="orders-list">
                                                        <% latestOrders.forEach(order=> { %>
                                                            <% const statusMap={ 'wc-completed' : 'bg-success'
                                                                , 'wc-processing' : 'bg-primary' , 'wc-pending'
                                                                : 'bg-warning text-dark' , 'wc-on-hold'
                                                                : 'bg-info text-dark' , 'wc-cancelled' : 'bg-danger'
                                                                , 'wc-refunded' : 'bg-secondary' , }; const
                                                                statusClass=statusMap[order.order_status]
                                                                || 'bg-secondary' ; const
                                                                statusLabel=order.order_status.replace('wc-', '' );
                                                                const customerName=order.customer_name || 'N/A' ; %>
                                                                <div class="py-3 border-bottom">
                                                                    <div
                                                                        class="d-flex justify-content-between align-items-center">
                                                                        <strong class="text-primary">
                                                                            <a href="/admin/orders/<%= order.order_id %>"
                                                                                class="fw-semibold text-decoration-none"
                                                                                target="_blank">
                                                                                #<%=order.order_id %>
                                                                            </a>
                                                                        </strong>
                                                                        <span
                                                                            class="badge text-capitalize <%= statusClass %>">
                                                                            <%= statusLabel %>
                                                                        </span>
                                                                    </div>
                                                                    <div class="d-flex justify-content-between mt-1">
                                                                        <div>
                                                                            <small class="text-dark fw-semibold"><i
                                                                                    class="ri-user-line me-1"></i>
                                                                                <%= customerName %>
                                                                            </small><br>
                                                                            <% if (order.phone) { %>
                                                                                <small class="text-muted"><i
                                                                                        class="ri-phone-line me-1"></i>
                                                                                    <%= order.phone %>
                                                                                </small><br>
                                                                                <% } %>
                                                                                    <small class="text-muted"><i
                                                                                            class="ri-calendar-line me-1"></i>
                                                                                        <%= new
                                                                                            Date(order.order_date).toLocaleDateString('en-IN')
                                                                                            %>
                                                                                    </small>
                                                                        </div>
                                                                        <div class="text-end">
                                                                            <span class="fw-bold text-success">₹<%=
                                                                                    Number(order.total || 0).toFixed(2)
                                                                                    %></span>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <% }) %>
                                                    </div>

                                                    <div class="text-end mt-3">
                                                        <button class="btn btn-sm btn-light-info" id="btn-orders-more"
                                                            data-offset="5"
                                                            data-endpoint="/admin/load-more/orders"
                                                            data-target="orders-list" data-type="orders"
                                                            onclick="loadMore(this)">
                                                            View More
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- ============ RECENT USERS ============ -->
                                        <div class="col-xl-4 col-lg-4 mb-4">
                                            <div class="card border-0 rounded-4 shadow-sm h-100">
                                                <div class="card-body">
                                                    <div class="d-flex justify-content-between align-items-center mb-4">
                                                        <h4 class="card-title mb-0 fw-bold">Recent Users</h4>
                                                        <span class="badge bg-primary">New</span>
                                                    </div>

                                                    <div id="users-list">
                                                        <% recentUsers.forEach(user=> { %>
                                                            <div
                                                                class="d-flex align-items-center gap-3 py-3 border-bottom">
                                                                <div class="flex-shrink-0 rounded-circle text-white d-flex align-items-center justify-content-center"
                                                                    style="background: linear-gradient(135deg,#667eea,#764ba2); min-width:40px; width:40px; height:40px;">
                                                                    <span class="fw-bold fs-6">
                                                                        <%= (user.display_name || user.user_email || '?'
                                                                            ).charAt(0).toUpperCase() %>
                                                                    </span>
                                                                </div>
                                                                <div class="flex-grow-1 overflow-hidden">
                                                                    <div class="fw-semibold text-dark text-truncate">
                                                                        <%= user.display_name || 'N/A' %>
                                                                    </div>
                                                                    <small class="text-muted d-block text-truncate"><i
                                                                            class="ri-mail-line me-1"></i>
                                                                        <%= user.user_email %>
                                                                    </small>
                                                                    <% if (user.phone) { %>
                                                                        <small class="text-muted d-block"><i
                                                                                class="ri-phone-line me-1"></i>
                                                                            <%= user.phone %>
                                                                        </small>
                                                                        <% } %>
                                                                            <% if (user.address) { %>
                                                                                <small
                                                                                    class="text-muted d-block text-truncate"><i
                                                                                        class="ri-map-pin-line me-1"></i>
                                                                                    <%= user.address %>
                                                                                </small>
                                                                                <% } %>
                                                                </div>
                                                            </div>
                                                            <% }) %>
                                                    </div>

                                                    <div class="text-end mt-3">
                                                        <button class="btn btn-sm btn-light-primary" id="btn-users-more"
                                                            data-offset="5" data-endpoint="/admin/load-more/users"
                                                            data-target="users-list" data-type="users"
                                                            onclick="loadMore(this)">
                                                            View More
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- ============ PRODUCT CATEGORIES ============ -->
                                        <div class="col-xl-4 col-lg-4 mb-4">
                                            <div class="card border-0 rounded-4 shadow-sm h-100">
                                                <div class="card-body">
                                                    <div class="d-flex justify-content-between align-items-center mb-4">
                                                        <h4 class="card-title mb-0 fw-bold">Product Categories</h4>
                                                        <span class="badge bg-warning text-dark">Featured</span>
                                                    </div>

                                                    <div id="categories-list">
                                                        <% categoryProducts.forEach(item=> { %>
                                                            <div
                                                                class="d-flex align-items-center justify-content-between py-3 border-bottom">
                                                                <div class="d-flex align-items-center gap-2">
                                                                    <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center"
                                                                        style="width:36px;height:36px;flex-shrink:0;">
                                                                        <i class="ri-folder-line text-primary"></i>
                                                                    </div>
                                                                    <span class="fw-semibold text-dark">
                                                                        <%= item.category_name %>
                                                                    </span>
                                                                </div>
                                                                <span
                                                                    class="badge bg-primary bg-opacity-25 text-primary fw-bold px-3 py-2">
                                                                    <%= item.product_count %> Products
                                                                </span>
                                                            </div>
                                                            <% }) %>
                                                    </div>

                                                    <div class="text-end mt-3">
                                                        <a href="/admin/products/categories"
                                                            class="btn btn-sm btn-light-warning" target="_blank">
                                                            View All
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                    <!-- end dashboard grid -->

                </div>
            </div>

            <div class="chat-windows"></div>

            <%- include('../partials/scripts') %>

                <!-- ===================== LOAD MORE SCRIPT ===================== -->
                <script>

                    async function loadMore(btn) {
                        const offset = parseInt(btn.dataset.offset) || 5;
                        const endpoint = btn.dataset.endpoint;
                        const target = document.getElementById(btn.dataset.target);
                        const type = btn.dataset.type;
                        const limit = 5;

                        btn.disabled = true;
                        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Loading…';

                        try {
                            const res = await fetch(`${endpoint}?offset=${offset}&limit=${limit}`);
                            const json = await res.json();

                            if (!json.success || !json.data.length) {
                                btn.innerHTML = 'No More Records';
                                btn.disabled = true;
                                return;
                            }

                            json.data.forEach(item => {
                                const el = document.createElement('div');
                                el.innerHTML = buildRow(type, item);
                                // append each child node so we don't wrap in an extra div
                                while (el.firstChild) target.appendChild(el.firstChild);
                            });

                            btn.dataset.offset = offset + json.data.length;
                            btn.disabled = false;
                            btn.innerHTML = 'View More';

                            if (json.data.length < limit) {
                                btn.innerHTML = 'No More Records';
                                btn.disabled = true;
                            }

                        } catch (e) {
                            console.error(e);
                            btn.innerHTML = 'Error – Retry';
                            btn.disabled = false;
                        }
                    }

                    /** Render a row HTML string based on widget type */
                    function buildRow(type, d) {
                        const placeholder = '/admin/public/images/placeholder.png';

                        if (type === 'lowstock') {
                            return `
                                <div class="d-flex align-items-center gap-3 py-3 border-bottom">
                                    <div class="flex-shrink-0">
                                    <img src="${d.thumbnail || placeholder}" alt="${escHtml(d.product_title)}"
                                        width="50" height="50" class="rounded" style="object-fit:cover;">
                                    </div>
                                    <div class="flex-grow-1 overflow-hidden">
                                    <div class="fw-semibold text-dark text-truncate">${escHtml(d.product_title)}</div>
                                    <small class="text-muted">Product ID: #${d.ID}</small>
                                    </div>
                                    <div>
                                    <span class="badge bg-danger">${d.stock} Left</span>
                                    </div>
                                </div>`;
                        }

                        if (type === 'bestsellers') {

                            return `
    
                                <div class="d-flex align-items-center gap-3 py-3 border-bottom">

                                    <!-- Image -->
                                    <div class="flex-shrink-0 position-relative">

                                        <img
                                            src="${d.thumbnail || placeholder}"
                                            alt="${escHtml(d.title)}"
                                            class="rounded"
                                            width="55"
                                            height="55"
                                            style="object-fit:cover;"
                                        >

                                    </div>

                                    <!-- Product Info -->
                                    <div class="flex-grow-1 overflow-hidden">

                                        <div class="fw-semibold text-dark text-truncate">

                                            <a
                                                href="/product/${d.slug}"
                                                class="text-decoration-none text-dark"
                                            >
                                                ${escHtml(d.title)}
                                            </a>

                                        </div>

                                        <small class="text-muted d-block">

                                            <i class="ri-shopping-bag-line"></i>

                                            ${d.totalSold} sold

                                        </small>

                                        <small class="text-success fw-semibold">

                                            ₹${Number(d.price || 0).toFixed(2)}

                                        </small>

                                    </div>

                                    <!-- Right Badge -->
                                    <div class="text-end">

                                        <span
                                            class="badge bg-success bg-opacity-10 text-success fw-bold fs-6 px-3 py-2"
                                        >
                                            ${d.totalSold}
                                        </span>

                                    </div>

                                </div>
                            
                            `;
                        }

                        if (type === 'orders') {

                            const statusMap = {
                                'wc-completed': 'bg-success',
                                'wc-processing': 'bg-primary',
                                'wc-pending': 'bg-warning text-dark',
                                'wc-on-hold': 'bg-info text-dark',
                                'wc-cancelled': 'bg-danger',
                                'wc-refunded': 'bg-secondary',
                            };

                            const cls = statusMap[d.order_status] || 'bg-secondary';

                            const label = (d.order_status || '')
                                .replace('wc-', '');

                            const name = d.customer_name || 'N/A';

                            const date = new Date(d.order_date)
                                .toLocaleDateString('en-IN');

                            const total = parseFloat(d.total || 0)
                                .toFixed(2);

                            const phone = d.phone
                                ? `<small class="text-muted">
                                        <i class="ri-phone-line me-1"></i>
                                        ${escHtml(d.phone)}
                                    </small><br>`
                                : '';

                            return `
                                <div class="py-3 border-bottom">

                                    <div class="d-flex justify-content-between align-items-center">
                                        <strong class="text-primary">
                                            <a href="/admin/orders/${d.order_id}"
                                              class="fw-semibold text-decoration-none" target="_blank">
                                                    #${d.order_id}
                                            </a>
                                        </strong>

                                        <span class="badge text-capitalize ${cls}">
                                            ${label}
                                        </span>
                                    </div>

                                    <div class="d-flex justify-content-between mt-1">

                                        <div>
                                            <small class="text-dark fw-semibold">
                                                <i class="ri-user-line me-1"></i>
                                                ${escHtml(name)}
                                            </small><br>

                                            ${phone}

                                            <small class="text-muted">
                                                <i class="ri-calendar-line me-1"></i>
                                                ${date}
                                            </small>
                                        </div>

                                        <div class="text-end">
                                            <span class="fw-bold text-success">
                                                ₹${total}
                                            </span>
                                        </div>

                                    </div>

                                </div>`;
                        }

                        if (type === 'users') {
                            const initial = (d.display_name || d.user_email || '?').charAt(0).toUpperCase();
                            const phone = d.phone ? `<small class="text-muted d-block"><i class="ri-phone-line me-1"></i>${escHtml(d.phone)}</small>` : '';
                            const address = d.address ? `<small class="text-muted d-block text-truncate"><i class="ri-map-pin-line me-1"></i>${escHtml(d.address)}</small>` : '';
                            return `
                                <div class="d-flex align-items-center gap-3 py-3 border-bottom">
                                    <div class="flex-shrink-0 rounded-circle text-white d-flex align-items-center justify-content-center"
                                        style="background:linear-gradient(135deg,#667eea,#764ba2);min-width:40px;width:40px;height:40px;">
                                    <span class="fw-bold fs-6">${initial}</span>
                                    </div>
                                    <div class="flex-grow-1 overflow-hidden">
                                    <div class="fw-semibold text-dark text-truncate">${escHtml(d.display_name || 'N/A')}</div>
                                    <small class="text-muted d-block text-truncate"><i class="ri-mail-line me-1"></i>${escHtml(d.user_email)}</small>
                                    ${phone}
                                    ${address}
                                    </div>
                                </div>`;
                        }

                        return '';
                    }

                    /** Escape HTML to prevent XSS */
                    function escHtml(str) {
                        if (!str) return '';
                        return String(str)
                            .replace(/&/g, '&amp;')
                            .replace(/</g, '&lt;')
                            .replace(/>/g, '&gt;')
                            .replace(/"/g, '&quot;')
                            .replace(/'/g, '&#39;');
                    }
                </script>


                <%- include('../partials/footer') %>