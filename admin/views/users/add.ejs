<%- include('../partials/head') %>

  <% var u=locals.user || null; var isEdit=!!u; var meta=(u && u.meta) ? u.meta : {}; %>

    <%- include('../partials/navbar') %>
      <%- include('../partials/sidebar') %>

        <div class="page-wrapper">

          <div class="page-breadcrumb">
            <div class="row">
              <div class="col-7 align-self-center">
                <h4 class="page-title">
                  <%= isEdit ? 'Edit User' : 'Add User' %>
                </h4>
                <div class="d-flex align-items-center">
                  <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                      <li class="breadcrumb-item"><a href="/admin/dashboard">Home</a></li>
                      <li class="breadcrumb-item"><a href="/admin/users">Users</a></li>
                      <li class="breadcrumb-item active">
                        <%= isEdit ? 'Edit' : 'Add' %>
                      </li>
                    </ol>
                  </nav>
                </div>
              </div>
              <div class="col-5 align-self-center text-end">
                <a href="/admin/users" class="btn-view-product btn-view-product--inline na-view-all-btn">
                  <div class="d-flex align-items-center gap-1">
                    <i data-feather="arrow-left" class="feather-sm"></i> Back
                  </div>
                </a>
              </div>
            </div>
          </div>

          <div class="container-fluid">

            <% if (locals.errors) { %>
              <div class="alert alert-danger alert-dismissible fade show">
                <i data-feather="alert-circle" class="feather-sm me-1"></i>
                <%= locals.errors %>
                  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
              </div>
              <% } %>

                <form action="<%= isEdit ? '/admin/users/update/' + u.ID : '/admin/users' %>"
                  method="POST" id="userForm">

                  <%# Hidden fields — derived from email and display_name %>
                    <input type="hidden" name="user_login" id="hiddenUserLogin"
                      value="<%= isEdit ? u.user_login    : '' %>" />
                    <input type="hidden" name="user_nicename" id="hiddenUserNicename"
                      value="<%= isEdit ? u.user_nicename : '' %>" />

                    <div class="row">

                      <!-- ══ LEFT COLUMN ══ -->
                      <div class="col-lg-8">

                        <!-- Account Info -->
                        <div class="card mb-3">
                          <div class="card-body">
                            <h4 class="card-title mb-3 pb-3 border-bottom">Account Information</h4>
                            <div class="row">

                              <div class="col-md-6">
                                <div class="mb-3">
                                  <label class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
                                  <input type="email" name="user_email" id="userEmail" class="form-control"
                                    placeholder="email@example.com" value="<%= isEdit ? (u.user_email || '') : '' %>"
                                    oninput="syncEmailToLogin(this.value)" required />
                                  <small class="text-muted">Used as username for login</small>
                                </div>
                              </div>

                              <div class="col-md-6">
                                <div class="mb-3">
                                  <label class="form-label fw-semibold">
                                    Password <% if (!isEdit) { %><span class="text-danger">*</span>
                                      <% } %>
                                  </label>
                                  <div class="input-group">
                                    <input type="password" name="user_pass" id="userPass" class="form-control"
                                      placeholder="<%= isEdit ? 'Leave blank to keep current' : 'Enter password' %>"
                                      <%=!isEdit ? 'required' : '' %> />
                                    <button type="button" class="btn btn-outline-secondary" onclick="togglePassword()">
                                      <i data-feather="eye" id="eyeIcon" style="width:16px;height:16px;"></i>
                                    </button>
                                  </div>
                                  <% if (isEdit) { %>
                                    <small class="text-muted">Leave blank to keep current password</small>
                                    <% } %>
                                </div>
                              </div>

                              <div class="col-md-6">
                                <div class="mb-3">
                                  <label class="form-label fw-semibold">Display Name</label>
                                  <input type="text" name="display_name" id="displayName" class="form-control"
                                    placeholder="Full name shown in UI"
                                    value="<%= isEdit ? (u.display_name || '') : '' %>"
                                    oninput="syncDisplayToNicename(this.value)" />
                                </div>
                              </div>

                              <div class="col-md-6">
                                <div class="mb-3">
                                  <label class="form-label fw-semibold">Website URL</label>
                                  <input type="url" name="user_url" class="form-control"
                                    placeholder="https://example.com" value="<%= isEdit ? (u.user_url || '') : '' %>" />
                                </div>
                              </div>

                            </div>
                          </div>
                        </div>

                        <!-- Personal Info -->
                        <div class="card mb-3">
                          <div class="card-body">
                            <h4 class="card-title mb-3 pb-3 border-bottom">Personal Information</h4>
                            <div class="row">

                              <div class="col-md-6">
                                <div class="mb-3">
                                  <label class="form-label fw-semibold">First Name</label>
                                  <input type="text" name="meta_first_name" class="form-control"
                                    placeholder="First name" value="<%= meta.first_name || '' %>" />
                                </div>
                              </div>

                              <div class="col-md-6">
                                <div class="mb-3">
                                  <label class="form-label fw-semibold">Last Name</label>
                                  <input type="text" name="meta_last_name" class="form-control" placeholder="Last name"
                                    value="<%= meta.last_name || '' %>" />
                                </div>
                              </div>

                              <div class="col-md-6">
                                <div class="mb-3">
                                  <label class="form-label fw-semibold">Phone Number</label>
                                  <input type="tel" name="meta_phone" class="form-control" placeholder="+91 99999 99999"
                                    value="<%= meta.phone || '' %>" />
                                </div>
                              </div>

                              <div class="col-md-6">
                                <div class="mb-3">
                                  <label class="form-label fw-semibold">Date of Birth</label>
                                  <input type="date" name="meta_dob" class="form-control"
                                    value="<%= meta.dob || '' %>" />
                                </div>
                              </div>

                              <div class="col-md-6">
                                <div class="mb-3">
                                  <label class="form-label fw-semibold">Gender</label>
                                  <select name="meta_gender" class="form-select">
                                    <option value="">Select gender</option>
                                    <option value="male" <%=meta.gender==='male' ? 'selected' : '' %>>Male</option>
                                    <option value="female" <%=meta.gender==='female' ? 'selected' : '' %>>Female
                                    </option>
                                    <option value="other" <%=meta.gender==='other' ? 'selected' : '' %>>Other</option>
                                  </select>
                                </div>
                              </div>

                              <div class="col-md-6">
                                <div class="mb-3">
                                  <label class="form-label fw-semibold">Profile Bio</label>
                                  <textarea name="meta_description" class="form-control" rows="2"
                                    placeholder="Short bio..."><%= meta.description || '' %></textarea>
                                </div>
                              </div>

                            </div>
                          </div>
                        </div>

                        <!-- Billing Address -->
                        <div class="card mb-3">
                          <div class="card-body">
                            <h4 class="card-title mb-3 pb-3 border-bottom">
                              <i data-feather="map-pin" class="feather-sm me-2"></i>Billing Address
                            </h4>
                            <div class="row">

                              <div class="col-12">
                                <div class="mb-3">
                                  <label class="form-label fw-semibold">Address Line 1</label>
                                  <input type="text" name="meta_billing_address_1" id="bAddr1" class="form-control"
                                    placeholder="Street address, flat no."
                                    value="<%= meta.billing_address_1 || '' %>" />
                                </div>
                              </div>

                              <div class="col-12">
                                <div class="mb-3">
                                  <label class="form-label fw-semibold">Address Line 2</label>
                                  <input type="text" name="meta_billing_address_2" id="bAddr2" class="form-control"
                                    placeholder="Area, landmark (optional)"
                                    value="<%= meta.billing_address_2 || '' %>" />
                                </div>
                              </div>

                              <div class="col-md-4">
                                <div class="mb-3">
                                  <label class="form-label fw-semibold">City</label>
                                  <input type="text" name="meta_billing_city" id="bCity" class="form-control"
                                    placeholder="City" value="<%= meta.billing_city || '' %>" />
                                </div>
                              </div>

                              <div class="col-md-4">
                                <div class="mb-3">
                                  <label class="form-label fw-semibold">State</label>
                                  <input type="text" name="meta_billing_state" id="bState" class="form-control"
                                    placeholder="State" value="<%= meta.billing_state || '' %>" />
                                </div>
                              </div>

                              <div class="col-md-4">
                                <div class="mb-3">
                                  <label class="form-label fw-semibold">Postcode</label>
                                  <input type="text" name="meta_billing_postcode" id="bPostcode" class="form-control"
                                    placeholder="PIN code" value="<%= meta.billing_postcode || '' %>" />
                                </div>
                              </div>

                              <div class="col-md-6">
                                <div class="mb-3">
                                  <label class="form-label fw-semibold">Country</label>
                                  <input type="text" name="meta_billing_country" id="bCountry" class="form-control"
                                    placeholder="Country" value="<%= meta.billing_country || 'India' %>" />
                                </div>
                              </div>

                              <div class="col-md-6">
                                <div class="mb-3">
                                  <label class="form-label fw-semibold">Billing Phone</label>
                                  <input type="tel" name="meta_billing_phone" id="bPhone" class="form-control"
                                    placeholder="Billing contact number" value="<%= meta.billing_phone || '' %>" />
                                </div>
                              </div>

                            </div>
                          </div>
                        </div>

                        <!-- Shipping Address -->
                        <div class="card mb-3">
                          <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom">
                              <h4 class="card-title mb-0">
                                <i data-feather="truck" class="feather-sm me-2"></i>Shipping Address
                              </h4>
                              <div class="form-check form-switch mb-0">
                                <input class="form-check-input" type="checkbox" id="sameAsBilling"
                                  <%=(!meta.shipping_address_1 || meta.shipping_address_1===meta.billing_address_1)
                                  ? 'checked' : '' %>
                                onchange="toggleShipping(this.checked)" />
                                <label class="form-check-label small fw-semibold" for="sameAsBilling">
                                  Same as Billing Address
                                </label>
                              </div>
                            </div>

                            <div id="shippingFields"
                              style="<%= (!meta.shipping_address_1 || meta.shipping_address_1 === meta.billing_address_1) ? 'display:none;' : '' %>">
                              <div class="row">

                                <div class="col-12">
                                  <div class="mb-3">
                                    <label class="form-label fw-semibold">Address Line 1</label>
                                    <input type="text" name="meta_shipping_address_1" id="sAddr1" class="form-control"
                                      placeholder="Street address, flat no."
                                      value="<%= meta.shipping_address_1 || '' %>" />
                                  </div>
                                </div>

                                <div class="col-12">
                                  <div class="mb-3">
                                    <label class="form-label fw-semibold">Address Line 2</label>
                                    <input type="text" name="meta_shipping_address_2" id="sAddr2" class="form-control"
                                      placeholder="Area, landmark (optional)"
                                      value="<%= meta.shipping_address_2 || '' %>" />
                                  </div>
                                </div>

                                <div class="col-md-4">
                                  <div class="mb-3">
                                    <label class="form-label fw-semibold">City</label>
                                    <input type="text" name="meta_shipping_city" id="sCity" class="form-control"
                                      placeholder="City" value="<%= meta.shipping_city || '' %>" />
                                  </div>
                                </div>

                                <div class="col-md-4">
                                  <div class="mb-3">
                                    <label class="form-label fw-semibold">State</label>
                                    <input type="text" name="meta_shipping_state" id="sState" class="form-control"
                                      placeholder="State" value="<%= meta.shipping_state || '' %>" />
                                  </div>
                                </div>

                                <div class="col-md-4">
                                  <div class="mb-3">
                                    <label class="form-label fw-semibold">Postcode</label>
                                    <input type="text" name="meta_shipping_postcode" id="sPostcode" class="form-control"
                                      placeholder="PIN code" value="<%= meta.shipping_postcode || '' %>" />
                                  </div>
                                </div>

                                <div class="col-md-6">
                                  <div class="mb-3">
                                    <label class="form-label fw-semibold">Country</label>
                                    <input type="text" name="meta_shipping_country" id="sCountry" class="form-control"
                                      placeholder="Country" value="<%= meta.shipping_country || 'India' %>" />
                                  </div>
                                </div>

                                <div class="col-md-6">
                                  <div class="mb-3">
                                    <label class="form-label fw-semibold">Shipping Phone</label>
                                    <input type="tel" name="meta_shipping_phone" id="sPhone" class="form-control"
                                      placeholder="Shipping contact number" value="<%= meta.shipping_phone || '' %>" />
                                  </div>

                                </div>
                              </div>
                            </div>

                            <!-- Hidden copy fields (used when same as billing is checked) -->
                            <div id="shippingCopyFields"
                              style="<%= (!meta.shipping_address_1 || meta.shipping_address_1 === meta.billing_address_1) ? '' : 'display:none;' %>">
                              <input type="hidden" name="meta_shipping_address_1" id="hSAddr1"
                                value="<%= meta.billing_address_1 || '' %>" />
                              <input type="hidden" name="meta_shipping_address_2" id="hSAddr2"
                                value="<%= meta.billing_address_2 || '' %>" />
                              <input type="hidden" name="meta_shipping_city" id="hSCity"
                                value="<%= meta.billing_city     || '' %>" />
                              <input type="hidden" name="meta_shipping_state" id="hSState"
                                value="<%= meta.billing_state    || '' %>" />
                              <input type="hidden" name="meta_shipping_postcode" id="hSPostcode"
                                value="<%= meta.billing_postcode || '' %>" />
                              <input type="hidden" name="meta_shipping_phone" id="hSPhone"
                                value="<%= meta.billing_phone || '' %>" />
                              <input type="hidden" name="meta_shipping_country" id="hSCountry"
                                value="<%= meta.billing_country || 'India' %>" />
                            </div>

                          </div>
                        </div>

                      </div><!-- /col-lg-8 -->

                      <!-- ══ RIGHT COLUMN ══ -->
                      <div class="col-lg-4">

                        <!-- Avatar preview -->
                        <div class="card mb-3">
                          <div class="card-body text-center py-4">
                            <div
                              class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center mx-auto mb-3"
                              style="width:80px;height:80px;font-size:32px;font-weight:700;" id="avatarCircle">
                              <%= isEdit ? (u.display_name || u.user_login || '?' ).charAt(0).toUpperCase() : '?' %>
                            </div>
                            <div class="fw-semibold fs-6" id="avatarName">
                              <%= isEdit ? (u.display_name || u.user_login) : 'New User' %>
                            </div>
                            <small class="text-muted" id="avatarEmail">
                              <%= isEdit ? u.user_email : '' %>
                            </small>
                          </div>
                        </div>

                        <!-- Role & Status -->
                        <div class="card mb-3">
                          <div class="card-body">
                            <h5 class="card-title mb-3 pb-2 border-bottom">Role & Status</h5>

                            <div class="mb-3">
                              <label class="form-label fw-semibold">User Type</label>
                              <select name="user_type" class="form-select">
                                <% userTypes.forEach(function(ut) { %>
                                  <option value="<%= ut.user_type_id %>" <%=isEdit && u.user_type==ut.user_type_id
                                    ? 'selected' : '' %>>
                                    <%= ut.user_type %>
                                  </option>
                                  <% }) %>
                              </select>
                            </div>

                            <div class="mb-3">
                              <label class="form-label fw-semibold">Account Status</label>
                              <select name="user_status" class="form-select">
                                <option value="0" <%=(!isEdit || u.user_status==0) ? 'selected' : '' %>>Active</option>
                                <option value="1" <%=(isEdit && u.user_status==1) ? 'selected' : '' %>>Inactive</option>
                              </select>
                            </div>

                            <% if (isEdit && u.user_registered) { %>
                              <div class="text-muted small mt-3 pt-3 border-top">
                                <div><strong>ID:</strong> #<%= u.ID %>
                                </div>
                                <div><strong>Username:</strong>
                                  <%= u.user_login %>
                                </div>
                                <div><strong>Registered:</strong>
                                  <%= new Date(u.user_registered).toLocaleDateString('en-IN') %>
                                </div>
                              </div>
                              <% } %>
                          </div>
                        </div>



                        <!-- Save -->
                        <div class="card mb-3">
                          <div class="card-body">
                            <div class="d-grid gap-2">
                              <button type="submit" class="btn btn-primary rounded-pill">
                                <div class="d-flex align-items-center justify-content-center gap-1">
                                  <i data-feather="save" class="feather-sm"></i>
                                  <%= isEdit ? 'Update User' : 'Create User' %>
                                </div>
                              </button>
                              <a href="/admin/users" class="btn btn-outline-secondary rounded-pill text-center">
                                Cancel
                              </a>
                            </div>
                          </div>
                        </div>

                      </div><!-- /col-lg-4 -->
                    </div><!-- /row -->
                </form>
          </div>
        </div>

        <%- include('../partials/scripts') %>
        
        <script>
          document.addEventListener("DOMContentLoaded", function () {
            var checkbox = document.getElementById('sameAsBilling');
            if (checkbox) {
              toggleShipping(checkbox.checked);
            }
          });
          // ── Sync email → user_login (hidden) ─────────────────────────────────────────
          function syncEmailToLogin(email) {
            // user_login = email (full email as username)
            document.getElementById('hiddenUserLogin').value = email;
            document.getElementById('avatarEmail').textContent = email;
          }

          // ── Sync display_name → user_nicename (hidden, slug version) ─────────────────
          function syncDisplayToNicename(name) {
            var slug = name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
            document.getElementById('hiddenUserNicename').value = slug;
            // Update avatar
            document.getElementById('avatarCircle').textContent = name.charAt(0).toUpperCase() || '?';
            document.getElementById('avatarName').textContent = name || 'New User';
          }

          // ── Toggle shipping address fields ────────────────────────────────────────────
          function toggleShipping(sameAsBilling) {
            var fields = document.getElementById('shippingFields');
            var copyFields = document.getElementById('shippingCopyFields');

            if (sameAsBilling) {
              // Hide editable fields
              fields.style.display = 'none';
              copyFields.style.display = '';

              // Disable visible inputs (VERY IMPORTANT)
              fields.querySelectorAll('input, select, textarea').forEach(el => {
                el.disabled = true;
              });

              // Enable hidden inputs
              copyFields.querySelectorAll('input').forEach(el => {
                el.disabled = false;
              });

              // Copy values
              copyBillingToShipping();

            } else {
              // Show editable fields
              fields.style.display = '';
              copyFields.style.display = 'none';

              // Enable visible inputs
              fields.querySelectorAll('input, select, textarea').forEach(el => {
                el.disabled = false;
              });

              // Disable hidden inputs (VERY IMPORTANT)
              copyFields.querySelectorAll('input').forEach(el => {
                el.disabled = true;
              });
            }
          }

          // ── Copy billing values → hidden shipping fields ──────────────────────────────
          function copyBillingToShipping() {
            document.getElementById('hSAddr1').value = document.getElementById('bAddr1').value;
            document.getElementById('hSAddr2').value = document.getElementById('bAddr2').value;
            document.getElementById('hSCity').value = document.getElementById('bCity').value;
            document.getElementById('hSState').value = document.getElementById('bState').value;
            document.getElementById('hSPostcode').value = document.getElementById('bPostcode').value;
            document.getElementById('hSCountry').value = document.getElementById('bCountry').value;
          }

          // Keep hidden shipping fields in sync when billing changes + same as billing is checked
          ['bAddr1', 'bAddr2', 'bCity', 'bState', 'bPostcode', 'bCountry'].forEach(function (id) {
            var el = document.getElementById(id);
            if (el) {
              el.addEventListener('input', function () {
                if (document.getElementById('sameAsBilling').checked) {
                  copyBillingToShipping();
                }
              });
            }
          });

          // ── Password toggle ───────────────────────────────────────────────────────────
          function togglePassword() {
            var input = document.getElementById('userPass');
            var icon = document.getElementById('eyeIcon');
            if (input.type === 'password') {
              input.type = 'text';
              icon.setAttribute('data-feather', 'eye-off');
            } else {
              input.type = 'password';
              icon.setAttribute('data-feather', 'eye');
            }
            feather.replace();
          }

          feather.replace();
        </script>

        <%- include('../partials/footer') %>