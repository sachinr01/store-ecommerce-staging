<%- include('../partials/head') %>

  <%- include('../partials/navbar') %>
    <%- include('../partials/sidebar') %>

      <div class="page-wrapper">

        <div class="page-breadcrumb">
          <div class="row">
            <div class="col-7 align-self-center">
              <h4 class="page-title">Categories</h4>
              <div class="d-flex align-items-center">
                <nav aria-label="breadcrumb">
                  <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/admin/dashboard">Home</a></li>
                    <li class="breadcrumb-item"><a href="/admin/blogs">Blogs</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Categories</li>
                  </ol>
                </nav>
              </div>
            </div>
            <div class="col-5 align-self-center text-end">
              <span class="btn-view-product btn-view-product--inline na-view-all-btn">
                <i data-feather="tag" class="feather-sm me-1"></i>
                <%= categories.length %> Total
              </span>
            </div>
          </div>
        </div>

        <div class="container-fluid">

          <!-- Flash messages -->
         
              <% if (locals.errors) { %>
                <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2">
                  <i data-feather="alert-circle" class="feather-sm flex-shrink-0"></i>
                  <%= locals.errors %>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
                <% } %>

                  <div class="row">

                    <!-- ══════════════════════════════════════════════
           LEFT COL — Add Category
      ══════════════════════════════════════════════ -->
                    <div class="col-lg-4 col-md-5">
                      <div class="card mb-4">
                        <div class="card-body">

                          <h4 class="card-title mb-3 pb-3 border-bottom">Add New Category</h4>

                          <form method="POST" action="/admin/blogs/category">

                            <div class="mb-3">
                              <label class="form-label fw-semibold">
                                Name <span class="text-danger">*</span>
                              </label>
                              <input type="text" name="category_name" id="add_name" class="form-control"
                                placeholder="e.g. T-Shirts" required />
                              <div class="form-text">The name is how it appears on your site.</div>
                            </div>

                            <div class="mb-3">
                              <label class="form-label fw-semibold">Parent Category</label>
                              <select name="parent_id" class="form-select">
                                <option value="0">— None (Top-level) —</option>
                                <% categories.forEach(c=> { %>
                                  <option value="<%= c.category_id %>">
                                    <%= c.category_name %>
                                  </option>
                                  <% }) %>
                              </select>
                              <div class="form-text">Categories can have a hierarchy.</div>
                            </div>

                            <div class="mb-3">
                              <label class="form-label fw-semibold">Description</label>
                              <textarea name="category_desc" class="form-control" rows="3"
                                placeholder="Optional category description..."></textarea>
                              <div class="form-text">Shown on some themes, not required.</div>
                            </div>

                            <div class="d-grid">
                              <button type="submit" class="btn-view-product btn-view-product--inline na-view-all-btn">
                                <div class="d-flex align-items-center justify-content-center gap-1">
                                  <i data-feather="plus-circle" class="feather-sm"></i>
                                  Add New Category
                                </div>
                              </button>
                            </div>

                          </form>
                        </div>
                      </div>
                    </div>
                    <!-- /LEFT -->


                    <!-- ══════════════════════════════════════════════
           RIGHT COL — Category Table
      ══════════════════════════════════════════════ -->
                    <div class="col-lg-8 col-md-7">
                      <div class="card mb-4">
                        <div class="card-body">

                          <!-- Table toolbar -->
                          <div
                            class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom flex-wrap gap-2">
                            <h4 class="card-title mb-0">Categories</h4>
                            <div class="d-flex align-items-center gap-2">
                              <div class="input-group input-group-sm">
                                <span class="input-group-text bg-transparent">
                                  <i data-feather="search" class="feather-sm text-muted"></i>
                                </span>
                                <input type="text" id="catSearch" class="form-control"
                                  placeholder="Search categories..." oninput="filterCats()" />
                              </div>
                              <span class="badge bg-light text-dark border fw-normal" id="catCountLabel">
                                <%= categories.length %> items
                              </span>
                            </div>
                          </div>

                          <% if (categories.length===0) { %>

                            <!-- Empty state -->
                            <div class="text-center py-5 text-muted">
                              <i data-feather="tag" class="d-block mx-auto mb-3 opacity-25"
                                style="width:48px;height:48px;"></i>
                              <p class="fw-semibold mb-1">No categories yet</p>
                              <small>Add your first category using the form on the left.</small>
                            </div>

                            <% } else { %>

                              <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0" id="catTable">
                                  <thead class="table-light">
                                    <tr>
                                      <th class="text-uppercase text-muted fw-semibold small"
                                        style="letter-spacing:.05em; font-size:.72rem;">Name</th>
                                      <th class="text-uppercase text-muted fw-semibold small"
                                        style="letter-spacing:.05em; font-size:.72rem;">Parent</th>
                                      <th class="text-uppercase text-muted fw-semibold small"
                                        style="letter-spacing:.05em; font-size:.72rem;">Actions</th>
                                    </tr>
                                  </thead>
                                  <tbody>
                                    <% categories.forEach(cat=> {
                                      const parentCat = categories.find(c => c.category_id === cat.parent_id);
                                      %>
                                      <tr>

                                        <!-- Name + description -->
                                        <td>
                                          <div class="d-flex align-items-center gap-2">
                                            <div
                                              class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0"
                                              style="width:34px;height:34px;">
                                              <i data-feather="tag" class="text-primary"
                                                style="width:14px;height:14px;"></i>
                                            </div>
                                            <div class="overflow-hidden">
                                              <div class="fw-semibold text-dark lh-sm">
                                                <%= cat.category_name %>
                                              </div>
                                              <% if (cat.category_desc) { %>
                                                <div class="text-muted small text-truncate" style="max-width:160px;">
                                                  <%= cat.category_desc %>
                                                </div>
                                                <% } %>
                                            </div>
                                          </div>
                                        </td>


                                        <!-- Parent -->
                                        <td>
                                          <% if (parentCat) { %>
                                            <span
                                              class="badge bg-primary bg-opacity-10 text-primary fw-normal px-2 py-1 rounded-pill">
                                              <i data-feather="corner-down-right" style="width:11px;height:11px;"
                                                class="me-1"></i>
                                              <%= parentCat.category_name %>
                                            </span>
                                            <% } else { %>
                                              <span class="text-muted small">—</span>
                                              <% } %>
                                        </td>

                                        <!-- Actions -->
                                        <td>
                                          <div class="d-flex align-items-center gap-1">
                                            <button class="btn btn-sm btn-outline-primary rounded-pill px-3" onclick='editCategory(
                                <%= cat.category_id %>,
                                "<%= cat.category_name.replace(/"/g, ' \\"') %>",
                                              "<%= cat.category_slug %>",
                                                "<%= cat.parent_id || 0 %>",
                                                  "<%= (cat.category_desc || '' ).replace(/"/g, '\\"' ) %>"
                                                    )'>
                                                    <div class="d-flex align-items-center gap-1">
                                                      <i data-feather="edit-2" class="feather-sm"></i> Edit
                                                    </div>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger rounded-pill px-3 delete-btn"
                                              data-id="<%= cat.category_id %>" data-name="<%= cat.category_name %>"
                                              data-url="/admin/blogs/category/delete/"
                                              data-title="Delete Blog Category">

                                              <div class="d-flex align-items-center gap-1">
                                                <i data-feather="trash-2" class="feather-sm"></i> Delete
                                              </div>
                                            </button>
                                          </div>
                                        </td>

                                      </tr>
                                      <% }) %>
                                  </tbody>
                                </table>
                              </div>

                              <!-- Footer -->
                              <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
                                <small class="text-muted" id="catFooterCount">
                                  Showing <%= categories.length %> of <%= categories.length %> categories
                                </small>
                                <small class="text-muted d-flex align-items-center gap-1">
                                  <i data-feather="info" class="feather-sm"></i>
                                  Click <strong class="mx-1">Edit</strong> to modify a category
                                </small>
                              </div>

                              <% } %>

                        </div>
                      </div>
                    </div>
                    <!-- /RIGHT -->

                  </div>
        </div>
      </div>
      <!-- /page-wrapper -->


      <!-- ══════════════════════════════════════════════
     EDIT MODAL
══════════════════════════════════════════════ -->
      <div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content">

            <div class="modal-header bg-light border-bottom">
              <div class="d-flex align-items-center gap-2">
                <div
                  class="rounded-circle bg-warning bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0"
                  style="width:34px;height:34px;">
                  <i data-feather="edit-2" class="text-warning" style="width:15px;height:15px;"></i>
                </div>
                <h5 class="modal-title mb-0 fw-semibold" id="editModalLabel">Edit Category</h5>
              </div>
              <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form id="editForm" method="POST">
              <input type="hidden" name="id" id="edit_id" />

              <div class="modal-body">

                <div class="mb-3">
                  <label class="form-label fw-semibold">
                    Name <span class="text-danger">*</span>
                  </label>
                  <input type="text" name="category_name" id="edit_name" class="form-control" required
                    placeholder="Category name" />
                </div>


                <div class="mb-3">
                  <label class="form-label fw-semibold">Parent Category</label>
                  <select name="parent_id" id="edit_parent" class="form-select">
                    <option value="0">— None (Top-level) —</option>
                    <% categories.forEach(c=> { %>
                      <option value="<%= c.category_id  %>">
                        <%= c.category_name %>
                      </option>
                      <% }) %>
                  </select>
                </div>

                <div class="mb-3">
                  <label class="form-label fw-semibold">Description</label>
                  <textarea name="category_desc" id="edit_desc" class="form-control" rows="3"
                    placeholder="Optional description..."></textarea>
                </div>

              </div>

              <div class="modal-footer bg-light border-top">
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">
                  Cancel
                </button>
                <button type="submit" class="btn btn-success rounded-pill px-4">
                  <div class="d-flex align-items-center gap-1">
                    <i data-feather="save" class="feather-sm"></i>
                    Update Category
                  </div>
                </button>
              </div>

            </form>
          </div>
        </div>
      </div>


      <%- include('../partials/scripts') %>
        <script>


          // Populate + show edit modal
          function editCategory(id, name, slug, parent, desc) {
            document.getElementById('edit_id').value = id;
            document.getElementById('edit_name').value = name;
            document.getElementById('edit_parent').value = parent || 0;
            document.getElementById('edit_desc').value = desc;
            document.getElementById('editForm').action = '/admin/blogs/category/update/' + id;
            new bootstrap.Modal(document.getElementById('editModal')).show();
          }

          // Live table search
          function filterCats() {
            var q = document.getElementById('catSearch').value.toLowerCase();
            var rows = document.querySelectorAll('#catTable tbody tr');
            var count = 0;
            rows.forEach(function (row) {
              var match = row.textContent.toLowerCase().includes(q);
              row.style.display = match ? '' : 'none';
              if (match) count++;
            });
            document.getElementById('catCountLabel').textContent = count + ' items';
            var fc = document.getElementById('catFooterCount');
            if (fc) fc.textContent = 'Showing ' + count + ' of ' + rows.length + ' categories';
          }

          feather.replace();
        </script>

        <%- include('../partials/footer') %>